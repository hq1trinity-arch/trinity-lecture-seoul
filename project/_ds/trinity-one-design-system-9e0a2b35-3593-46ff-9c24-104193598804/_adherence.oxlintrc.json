{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/indicators/**",
              "components/navigation/**",
              "components/overlays/**",
              "components/pickers/**",
              "components/system/**",
              "ui_kits/trinity-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard))/i]",
        "message": "Font not provided by the design system. Available: Pretendard."
      },
      {
        "selector": "JSXOpeningElement[name.name='SheetAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|onClick|preferred|destructive|key|ref|className|style|children)$/]",
        "message": "<SheetAction> doesn't accept that prop. Declared props: label, onClick, preferred, destructive."
      },
      {
        "selector": "JSXOpeningElement[name.name='SharePerson'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|initials|key|ref|className|style|children)$/]",
        "message": "<SharePerson> doesn't accept that prop. Declared props: name, initials."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|onClick|preferred|destructive|key|ref|className|style|children)$/]",
        "message": "<AlertAction> doesn't accept that prop. Declared props: label, onClick, preferred, destructive."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|status|square|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, status, square."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|away|busy|offline)$/]",
        "message": "<Avatar> status must be one of 'online' | 'away' | 'busy' | 'offline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, color, size, children."
      },
