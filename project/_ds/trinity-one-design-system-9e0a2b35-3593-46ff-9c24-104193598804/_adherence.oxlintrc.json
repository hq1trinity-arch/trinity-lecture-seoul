        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|brand|positive|warning|negative|count)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'brand' | 'positive' | 'warning' | 'negative' | 'count'."
